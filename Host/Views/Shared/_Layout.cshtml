<!DOCTYPE HTML>
<html>
	<head>
		<title>Renzyu</title>
		<meta http-equiv="content-type" content="text/html; charset=utf-8" />
		<meta name="description" content="" />
		<meta name="keywords" content="Renzyu, Gomoku, Play, Online" />
		<link href="https://fonts.googleapis.com/css?family=Ubuntu+Condensed" rel="stylesheet">
		<noscript>
			<link rel="stylesheet" href="/Content/5grid/core.css" />
			<link rel="stylesheet" href="/Content/5grid/core-desktop.css" />
			<link rel="stylesheet" href="/Content/5grid/core-1200px.css" />
			<link rel="stylesheet" href="/Content/5grid/core-noscript.css" />
			<link rel="stylesheet" href="/Content/style.css" />
			<link rel="stylesheet" href="/Content/style-desktop.css" />
		</noscript>
		<!--[if IE 9]><link rel="stylesheet" href="/Content/style-ie9.css" /><![endif]-->
		<script src="/Scripts/vendor/jquery.js"></script>
		<script src="/Scripts/vendor/knockout.js"></script>
		<script src="/Scripts/vendor/signalr.js"></script>
		<script src="/Content/5grid/init.js?use=mobile,desktop,1000px&amp;mobileUI=1&amp;mobileUI.theme=none&amp;mobileUI.titleBarHeight=55&amp;mobileUI.openerWidth=66"></script>
		<script src="/Scripts/Board.js"></script>
		@await RenderSectionAsync("scripts", required: false)
	</head>
	<body>
	<!-- ********************************************************* -->
		<div id="header-wrapper">
			<div class="5grid-layout">
				<div class="row">
					<div class="12u">
						<header id="header">
							<h1><a asp-controller="Home" asp-action="Index" class="mobileUI-site-name">Renzyu</a></h1>
							<nav class="mobileUI-site-nav">
								<a asp-controller="Home" asp-action="Index" class="current-page-item">Home</a>
							</nav>
						</header>
					</div>
				</div>
			</div>
		</div>
		<div id="main">
			<div class="5grid-layout">
				<div class="row main-row">
					@RenderBody()
				</div>
			</div>
		</div>
		<div id="footer-wrapper">
			<div class="5grid-layout">
				<div class="row">
					<div class="12u">
						<section>
							<p>Here should be some vivid description of how cool it is to play Renzyu</p>
						</section>
					</div>
				</div>
				<div class="row">
					<div class="12u">
						<div id="copyright">
							&copy; Petya Afanasiev. All rights reserved. | Design: <a href="http://html5up.net">HTML5 Up!</a> | Images: <a href="http://fotogrph.com">Fotogrph</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	<!-- ********************************************************* -->
	</body>
</html>
