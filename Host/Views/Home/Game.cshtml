@model Host.Models.GamePageViewModel
<div class="4u">
    <div>
        <h2 data-bind="text:message"></h2>
    </div>
    <div data-bind="visible:state()==7">
        <a asp-action="Game" class="button" target="_blank">Join another game</a>
    </div>
    @if (Model.Token != null)
    {
        <div>
            Send your opponent this <a asp-action="Game" asp-route-token="@Model.Token">private url</a>
            so he would join your game.
        </div>
    }
    else
    {
        <div class="ai-picker" data-bind="visible: state() == 8">
            <label for="ai-model">Choose your AI opponent</label>
            <select id="ai-model" data-bind="value: selectedAiModelId">
                @foreach (var aiModel in Model.AiModels)
                {
                    if (aiModel.IsBuiltIn)
                    {
                        <option value="@aiModel.Id">@aiModel.Name - depth 4 search</option>
                    }
                    else
                    {
                        <option value="@aiModel.Id">
                            @aiModel.Name - @aiModel.EpisodesTrained.ToString("N0") episodes,
                            @aiModel.EvaluationScore.ToString("P0") evaluation score
                        </option>
                    }
                }
            </select>
            <a href="#" class="button" data-bind="click: playWithComputer">Play selected AI</a>
        </div>
    }
</div>
<div class="8u">
    <div class="board-wrapper">
        <div class="board" data-bind="foreach: board.rows">
            <div class="row" data-bind="foreach: cells">
                <div class="cell" data-bind="css: {opponent: value()==2, host: value() ==1, win: value()==5 }, click: sendMove">
                </div>
            </div>
        </div>
    </div>

    <script type="text/javascript">
        $(function () {
            var myGame = new game('@(Model.Token?.ToString() ?? "")', '@Model.DefaultAiModelId');
            ko.applyBindings(myGame);
            myGame.initialize();
        });
    </script>
</div>
